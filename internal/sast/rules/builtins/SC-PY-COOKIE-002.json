        "arg_index": 0,
        "arg_text_missing_any": ["httponly", "HttpOnly"],
        "message_template": "Django set_cookie without httponly=True"
      },
      {
        "receiver_fqn": "Response",
        "callee": "set_cookie",
        "arg_index": 0,
        "arg_text_missing_any": ["httponly", "HttpOnly"],
        "message_template": "Response.set_cookie without httponly=True"
      },
      {
        "receiver_fqn": "response",
        "callee": "set_cookie",
        "arg_index": 0,
