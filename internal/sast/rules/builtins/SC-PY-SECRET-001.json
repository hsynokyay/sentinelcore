{
  "rule_id": "SC-PY-SECRET-001",
  "name": "Hardcoded credential in Python source",
  "language": "python",
  "cwe": ["CWE-798"],
  "owasp": ["A07:2021"],
  "severity": "high",
  "confidence": {
    "base": 0.75
  },
  "detection": {
    "kind": "ast_assign",
    "assign_patterns": [
      {
        "name_matches_any": [
          "(?i)(password|secret|token|api_key|access_key|private_key|auth_token|jwt_secret|db_password)"
        ],
        "min_value_length": 6,
        "exclude_values": [
          "(?i)^(test|changeme|TODO|placeholder|xxx)$",
          "^\\$\\{",
          "^\\{\\{"
        ],
        "require_entropy": true,
        "message_template": "Hardcoded credential: {{name}}"
      }
    ]
  },
  "description": "Secret value hardcoded in source.",
  "remediation": "Use environment variables or a secrets manager.",
  "references": [
    "https://cwe.mitre.org/data/definitions/798.html",
    "https://owasp.org/Top10/A07_2021-Identification_and_Authentication_Failures/"
  ]
}
