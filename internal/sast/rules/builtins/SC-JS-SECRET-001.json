{
  "schema_version": 2,
  "rule_id": "SC-JS-SECRET-001",
  "name": "Hardcoded credential in JavaScript/TypeScript source",
  "languages": [
    "javascript"
  ],
  "category": "secret",
  "cwe": [
    "CWE-798"
  ],
  "owasp": [
    "A07:2021"
  ],
  "severity": "high",
  "description": "A secret is hardcoded as a string literal in source code.",
  "remediation": "Move secrets to environment variables or a secrets manager.",
  "references": [
    "https://cwe.mitre.org/data/definitions/798.html"
  ],
  "detection": {
    "kind": "ast_assign",
    "assign_patterns": [
      {
        "name_matches_any": [
          "(?i)(password|secret|token|apiKey|api_key|accessKey|privateKey|authToken|jwtSecret)"
        ],
        "min_value_length": 6,
        "exclude_values": [
          "(?i)^(test|changeme|TODO|placeholder|xxx)$",
          "^\\$\\{",
          "^\\{\\{"
        ],
        "require_entropy": true,
        "message_template": "Hardcoded credential: {{name}}"
      }
    ]
  },
  "confidence": {
    "base": 0.75
  }
}
