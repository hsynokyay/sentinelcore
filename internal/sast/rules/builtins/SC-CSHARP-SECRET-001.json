{
  "rule_id": "SC-CSHARP-SECRET-001",
  "name": "Hardcoded credential: {{name}}",
  "language": "csharp",
  "cwe": ["CWE-798", "CWE-259"],
  "owasp": ["A07:2021"],
  "severity": "high",
  "description": "A secret or credential value (password, API key, token, or access key) is hardcoded as a string literal in C# source code. Hardcoded secrets are visible to anyone with access to the source, cannot be rotated without a code change, and are frequently exposed in version control history.",
  "remediation": "Move secret values to environment variables (Environment.GetEnvironmentVariable), configuration providers (IConfiguration + appsettings.json), or a secrets manager (Azure Key Vault, AWS Secrets Manager, HashiCorp Vault). Load secrets at runtime via a secure configuration provider. Never commit secrets to source code, even in test or example files.",
  "references": [
    "https://cwe.mitre.org/data/definitions/798.html",
    "https://cwe.mitre.org/data/definitions/259.html",
    "https://owasp.org/Top10/A07_2021-Identification_and_Authentication_Failures/",
    "https://cheatsheetseries.owasp.org/cheatsheets/Secrets_Management_Cheat_Sheet.html"
  ],
  "detection": {
    "kind": "ast_assign",
    "assign_patterns": [
      {
        "name_matches_any": [
          "(?i)(password|passwd|pwd|secret|token|apiKey|api_key|accessKey|access_key|clientSecret|client_secret|privateKey|private_key|authToken|auth_token|jwtSecret|jwt_secret|signingKey|signing_key|encryptionKey|encryption_key|dbPassword|db_password|masterKey|master_key|secretKey|secret_key|bearerToken|bearer_token|connectionString|connection_string)"
        ],
        "min_value_length": 6,
        "exclude_values": [
          "(?i)^(test|example|placeholder|changeme|TODO|FIXME|xxx+|yyy+|zzz+|null|none|empty|default|dummy|fake|mock|sample)$",
          "(?i)^your[_-]",
          "^\\$\\{",
          "^\\{\\{",
          "^<",
          "^\\*+$",
          "^\\s*$",
          "^(true|false)$"
        ],
        "require_entropy": true,
        "message_template": "Hardcoded credential: {{name}}"
      },
      {
        "name_matches_any": ["(?i)."],
        "min_value_length": 10,
        "value_prefixes_any": [
          "ghp_", "gho_", "ghs_", "ghr_",
          "github_pat_",
          "sk-live-", "sk_live_", "pk-live-",
          "AKIA",
          "xoxb-", "xoxp-", "xoxs-",
          "eyJhbG",
          "Bearer ",
          "Basic ",
          "-----BEGIN"
        ],
        "exclude_values": [],
        "require_entropy": false,
        "message_template": "Hardcoded credential with known prefix: {{name}}"
      }
    ]
  },
  "confidence": {
    "base": 0.75
  },
  "examples": {
    "vulnerable": "private static readonly string ApiKey = \"sk-live-abcdef1234567890\";",
    "fixed": "private static readonly string ApiKey = Environment.GetEnvironmentVariable(\"API_KEY\");"
  }
}
