<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Vulnerable Test Application</display-name>

    <!-- VULN: Long session timeout -->
    <session-config>
        <session-timeout>1440</session-timeout>
        <cookie-config>
            <!-- VULN: Cookie not HTTP-only or Secure -->
            <http-only>false</http-only>
            <secure>false</secure>
        </cookie-config>
        <!-- VULN: URL session tracking enables session leak -->
        <tracking-mode>URL</tracking-mode>
    </session-config>

    <!-- VULN: Detailed error pages disclose info -->
    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/error.jsp</location>
    </error-page>

    <!-- VULN: Servlets without auth constraints -->
    <servlet>
        <servlet-name>SqlServlet</servlet-name>
        <servlet-class>com.test.vuln.SQLInjectionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SqlServlet</servlet-name>
        <url-pattern>/sql</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CmdServlet</servlet-name>
        <servlet-class>com.test.vuln.CommandInjectionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CmdServlet</servlet-name>
        <url-pattern>/cmd</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>XxeServlet</servlet-name>
        <servlet-class>com.test.vuln.XXEAndSSRFServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>XxeServlet</servlet-name>
        <url-pattern>/xxe</url-pattern>
    </servlet-mapping>

    <!-- VULN: Admin servlet without security constraint -->
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.test.vuln.AuthenticationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin/*</url-pattern>
    </servlet-mapping>

    <!-- VULN: Missing security constraints for the entire app -->

</web-app>
